{
  "title": "Sepsis — Drift & Serving (watch)",
  "uid": "sepsis-drift",
  "tags": ["sepsis", "drift", "h4"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-7d", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Per-feature drift distance (PSI/JS)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"expr": "drift_value_distance", "legendFormat": "{{feature}}"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Per-feature missing-rate JS",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "drift_missing_js", "legendFormat": "{{feature}}"}
      ]
    },
    {
      "id": 3,
      "type": "state-timeline",
      "title": "Per-feature watch state (1 = drift observed)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "drift_state", "legendFormat": "{{feature}}"}
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dataset drift share / insufficient-data",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "drift_dataset_share", "legendFormat": "share"},
        {"expr": "drift_insufficient_data", "legendFormat": "insufficient"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Prediction probability distribution",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "rate(serve_pred_prob_bucket[5m])", "legendFormat": "{{le}}"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Serving input feature values (observed)",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {"expr": "serve_input_feature_value_count", "legendFormat": "{{feature}}"}
      ]
    }
  ]
}
